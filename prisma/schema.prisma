datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client"
  output   = "../src/shared/infrastructure/prisma/generated"
}


model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  @@map("iam_users")
}